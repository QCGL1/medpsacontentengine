# ─────────────────────────────────────────────────────────────
# LOCAL DEV ONLY. Copy to `.env` and fill with PLACEHOLDER values
# for local testing. Do NOT put real keys here and do NOT commit .env.
#
# In production these come from GitHub Secrets (set by Prateek),
# NOT from this file. See SETUP_SAHIL.md "Dry-run mode".
# ─────────────────────────────────────────────────────────────

# Meta / Instagram + Facebook (owned by Prateek)
META_ACCESS_TOKEN=dummy-long-lived-token
META_PAGE_ID=000000000000000
META_IG_ACCOUNT_ID=000000000000000

# Image generation (Runway, paid — owned by Prateek)
RUNWAY_API_KEY=dummy-runway-key

# Anthropic (paid — owned by Prateek)
ANTHROPIC_API_KEY=dummy-anthropic-key

# Engine config (safe to edit)
DRY_RUN=true               # true = no real API calls; logs what WOULD happen
POSTS_PER_WEEK=7
TARGET_IG=true
TARGET_FB=true
